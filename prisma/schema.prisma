generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudyNode {
  id            String          @id @default(cuid())
  title         String
  slug          String          @unique
  type          String
  overview      String?         @db.Text
  details       String?         @db.LongText
  accent        String?
  sortOrder     Int             @default(0)
  parentId      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  parent        StudyNode?      @relation("StudyTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      StudyNode[]     @relation("StudyTree")
  studyLogs     StudyLog[]
  testRecords   TestRecord[]
  topicProgress TopicProgress?
  agentTasks    AgentTask[]
}

model TopicProgress {
  id             String     @id @default(cuid())
  studyNodeId    String     @unique
  checked        Boolean    @default(false)
  checkedAt      DateTime?
  revisionCount  Int        @default(0)
  lastRevisedAt  DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  studyNode      StudyNode  @relation(fields: [studyNodeId], references: [id], onDelete: Cascade)
}

model StudyLog {
  id           String     @id @default(cuid())
  studyNodeId  String?
  title        String
  logDate      DateTime
  hours        Float
  topicCount   Int        @default(0)
  completion   Int        @default(0)
  focusScore   Int?
  notes        String?    @db.Text
  studyNode    StudyNode? @relation(fields: [studyNodeId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model DailyLog {
  id              String   @id @default(cuid())
  logDate         DateTime @unique
  primaryFocus    String
  totalHours      Float
  wins            String?  @db.Text
  blockers        String?  @db.Text
  tomorrowPlan    String?  @db.Text
  disciplineScore Int      @default(0)
  completion      Int      @default(0)
  questionsSolved Int      @default(0)
  topicsStudied   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MoodEntry {
  id          String   @id @default(cuid())
  moodDate    DateTime @unique
  label       String
  energy      Int
  focus       Int
  stress      Int
  confidence  Int
  consistency Int
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TestRecord {
  id                 String     @id @default(cuid())
  studyNodeId        String?
  title              String
  examStage          String
  testType           String
  testDate           DateTime
  totalMarks         Float
  score              Float
  correctQuestions   Int?
  incorrectQuestions Int?
  attemptedQuestions Int?
  percentile         Float?
  timeMinutes        Int?
  notes              String?    @db.Text
  studyNode          StudyNode? @relation(fields: [studyNodeId], references: [id], onDelete: SetNull)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model EssaySubmission {
  id          String   @id @default(cuid())
  title       String
  prompt      String   @db.Text
  content     String   @db.LongText
  feedback    String?  @db.LongText
  score       Float?
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiConversation {
  id        String      @id @default(cuid())
  title     String
  persona   String      @default("guru")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AiMessage[]
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String         @db.LongText
  attachmentText String?        @db.LongText
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AiMemoryProfile {
  id          String   @id @default(cuid())
  persona     String   @unique
  summaryText String   @db.LongText
  summaryJson String?  @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AgentMission {
  id                  String      @id @default(cuid())
  title               String
  goal                String?     @db.Text
  mode                String      @default("MISSION_CONTROL")
  status              String      @default("READY")
  summary             String?     @db.LongText
  executionWindow     String?
  urgency             String?
  plannerNotes        String?     @db.LongText
  risksJson           String?     @db.LongText
  followUpsJson       String?     @db.LongText
  whyNowJson          String?     @db.LongText
  todayPlanJson       String?     @db.LongText
  dailyLogDraftJson   String?     @db.LongText
  contextSnapshotJson String?     @db.LongText
  model               String?
  launchedAt          DateTime    @default(now())
  lastActivatedAt     DateTime?
  appliedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  tasks               AgentTask[]
}

model AgentTask {
  id                String        @id @default(cuid())
  missionId         String
  linkedStudyNodeId String?
  title             String
  detail            String?       @db.Text
  rationale         String?       @db.Text
  taskType          String        @default("TASK")
  status            String        @default("TODO")
  priority          String        @default("MEDIUM")
  energyBand        String?
  source            String        @default("AI")
  checklistJson     String?       @db.LongText
  dueLabel          String?
  estimatedMinutes  Int?
  scheduledFor      DateTime?
  orderIndex        Int           @default(0)
  completionNotes   String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  mission           AgentMission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  linkedStudyNode   StudyNode?    @relation(fields: [linkedStudyNodeId], references: [id], onDelete: SetNull)

  @@index([missionId, status, orderIndex])
}
