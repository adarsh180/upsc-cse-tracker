DATABASE_URL="mysql://username:password@host:4000/database?sslaccept=strict"
AUTH_EMAIL="you@example.com"
AUTH_PASSWORD="your-password"
GOOGLE_GENERATIVE_AI_API_KEY="your-google-api-key"
GOOGLE_AI_MODEL_MISSION="gemma-3-27b-it"
GOOGLE_AI_MODEL_PRIMARY="gemma-3-27b-it"
GOOGLE_AI_MODEL_FALLBACK="gemma-3-12b-it"
NEXT_PUBLIC_APP_NAME="UPSC CSE Tracker"
PRELIMS_DATE="2027-05-23T00:00:00+05:30"
MAINS_DATE="2027-08-20T00:00:00+05:30"

# Web Push is free. Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="public-vapid-key"
VAPID_PRIVATE_KEY="private-vapid-key"
VAPID_SUBJECT="mailto:you@example.com"

# Telegram notifications (optional — used by morning/evening Guru broadcasts).
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"
# Used for "Open UPSC Tracker" links in Discord/Telegram messages.
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Cron jobs (7:00 AM IST briefing + 9:00 PM IST streak guard).
# Set the same value in Vercel env vars; Vercel sends it as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET="any-long-random-string"
# Optional model overrides for background agents (default to GOOGLE_AI_MODEL_PRIMARY):
# GOOGLE_AI_MODEL_DIGEST="gemma-3-27b-it"
# GOOGLE_AI_MODEL_REVIEW="gemma-3-27b-it"

# Cross-app notifications.
# In the UPSC project this must point to the NEET project, because it is the partner app.
CROSS_APP_NOTIFY_SECRET="same-random-secret-in-both-projects"
PARTNER_NOTIFY_ENDPOINT="https://neet-tracker-misti.vercel.app/api/cross-app-notifications"
